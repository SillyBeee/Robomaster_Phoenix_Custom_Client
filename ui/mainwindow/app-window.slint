import { AboutSlint, VerticalBox } from "std-widgets.slint";
import {MainMenu} from "main_menu.slint";
import { Callback_Factory } from "../callback_factory.slint";



export {Callback_Factory}

component SplashScreen inherits Rectangle{
    Image{
        width: 100%;
        height: 100%;
        source: @image-url("../images/logo_dark.png");  
        image-fit: contain; // 保持比例
    }
}

// 自定义窗口控制按钮 (关闭/最小化)
component WindowButton inherits Rectangle {
    in property <string> text;
    in property <color> hover-color: #ffffff20;
    in property <color> press-color: #ffffff40;
    callback clicked;

    width: 60px; height: 100%;
    background: touch.pressed ? root.press-color : (touch.has-hover ? root.hover-color : transparent);
    animate background { duration: 100ms; }

    Text { 
        text: root.text; 
        color: white; 
        font-size: 14px;
        vertical-alignment: center;
        horizontal-alignment: center;
    }
    touch := TouchArea { clicked => { root.clicked(); } }
}

export component MainWindow inherits Window {
    in-out property <length> window-width: 1920px;
    in-out property <length> window-height: 1080px;
    property <float> splash-opacity: 0.0; 
    property <float> menu-opacity: 0.0;   
    in-out property <bool> is_fullscreen: false;
    in-out property <bool> is_maximized: false; 
    
    title: "RoboMaster Custom Client";
    
    no-frame: true; 
    
    preferred-width: window-width;
    preferred-height: window-height;
    background: #000000; 

    // 2. 自定义边框/背景容器
    Rectangle {
        width: 100%; height: 100%;
        background: #1e1e2e; // 你的应用背景色
        border-radius: 8px;  // 圆角效果 (注意：某些系统上全屏或无边框可能不支持圆角裁剪)
        clip: true;          // 裁剪内容

        // 3. 主菜单 (在底层)
        MainMenu {
            y: 30px; // 给自定义标题栏留出空间
            height: parent.height - 30px;
            opacity: root.menu-opacity;
            visible: root.menu-opacity > 0; 
            animate opacity { duration: 1000ms; easing: ease-in-out; }
        }

        // 4. 启动页 (在上层)
        SplashScreen {
            opacity: root.splash-opacity;
            visible: root.splash-opacity > 0;
            animate opacity { duration: 1000ms; easing: ease-in-out; }
        }

        // 5. 自定义标题栏
        if (root.menu-opacity > 0.5) : Rectangle {
            x: 0; y: 0; width: 100%; height: 30px;
            background: @linear-gradient(90deg, #1a191924 0%, #84828205 100%); // 标题栏颜色
            z: 100; // 保证在最上层
            Text {
                text: root.title;
                color: #888;
                font-size: 21px;
                x: 30px;
                vertical-alignment: center;
            }

            // 拖动区域
            TouchArea {
                property <length> start-x;
                property <length> start-y;
                property <bool> is_pressed: false;

                pointer-event(event) => {
                    if (event.kind == PointerEventKind.down) {
                        self.start-x = self.mouse-x;
                        self.start-y = self.mouse-y;
                        self.is_pressed = true;
                    } else if (event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel) {
                        self.is_pressed = false;
                    }
                }

                moved => {
                    if (self.is_pressed) {
                        // 计算增量
                        let dx = self.mouse-x - self.start-x;
                        let dy = self.mouse-y - self.start-y;
                        
                        // 调用 C++ 移动窗口
                        Callback_Factory.move_window(dx, dy);
                    }
                }
                
            }

            // 窗口控制按钮 (右上角)
            HorizontalLayout {
                alignment: end;
                // 最小化
                WindowButton { 
                    text: "-"; 
                    clicked => { Callback_Factory.minimize_window(); } 
                }
                
                // 最大化/还原 (修改这里)
                WindowButton { 
                    // 根据状态显示不同图标：□ (最大化) 或 ❐ (还原)
                    text: root.is_maximized ? "❐" : "□"; 
                    clicked => { 
                        // 切换状态
                        root.is_maximized = !root.is_maximized;
                        // 调用 C++ 回调，传入新的状态
                        Callback_Factory.maximize_window(root.is_maximized); 
                    } 
                }
                
                // 关闭
                WindowButton { 
                    text: "✕"; 
                    hover-color: #ff0000aa;
                    press-color: #ff0000dd;
                    clicked => { Callback_Factory.close_window(); } 
                }
            }
        }
    }

    // ... existing timers ...
    step1-timer := Timer {
        interval: 200ms;
        triggered() => {
            root.splash-opacity = 1.0; 
            step1-timer.stop();        
            step2-timer.start();       
        }
    }

    step2-timer := Timer {
        interval: 800ms; 
        triggered() => {
            root.splash-opacity = 0.0; 
            root.menu-opacity = 1.0;   
            step2-timer.stop();
        }
    }

    init => {
        step1-timer.start();
    }
}
