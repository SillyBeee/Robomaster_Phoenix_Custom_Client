import { Base_Component, ComponentProps } from "base_component.slint";
import { HealthBar} from "std_components/health_bar.slint"; 
import { Callback_Factory } from "../callback_factory.slint";
import { Coordinate-3D } from "std_components/coordinate.slint";
import { Sight } from "std_components/sight.slint";
import { ModuleStatus } from "std_components/module_status.slint";
import { GameStatus } from "std_components/game_status.slint";
import { MapComponent } from "std_components/map.slint";
export component Component_Render inherits Rectangle {
    in-out property <bool> draggable: true;

    width: 100%;
    height: 100%;
    background: transparent;
    clip: true;

    for comp[i] in Callback_Factory.components: Base_Component {
        // 1. 统一管理定位和交互 (Base_Component)
        props: {
            container_width: root.width,
            container_height: root.height,
            container_index: i,
            rel_x: comp.rel_x,
            rel_y: comp.rel_y,
            rel_width: comp.rel_width,
            rel_height: comp.rel_height,
            background_color: comp.color,       
            opacity_value: comp.opacity,
            layer: comp.layer,
        };
        
        is_selected: i == Callback_Factory.current_component_index;
        draggable: root.draggable;

        // 2. 根据类型填充内容 (@children)

        if (comp.type == "sight") : Sight {
            width: 100%;
            height: 100%;
            props: parent.props;
            is_selected: parent.is_selected;
        }
        

        if (comp.type == "base" || comp.type == "") : Rectangle {
            width: 100%;
            height: 100%;
            background: comp.color;
            opacity: comp.opacity;
        }


        if (comp.type == "health_bar") : HealthBar {
            // 只需要传数据，不需要管定位
            width: 100%;
            height: 100%;
            props: parent.props; // 这里的 parent 是 Base_Component
            is_selected: parent.is_selected;
            // current_hp: ...
        }


        if (comp.type == "coordinate") : Coordinate-3D {
            width: 100%;
            height: 100%;
            props: parent.props;
            is_selected: parent.is_selected;
        }


        


        if (comp.type == "module_status") : ModuleStatus {
            width: 100%;
            height: 100%;
            props: parent.props;
            is_selected: parent.is_selected;
        }


        if (comp.type == "game_status"): GameStatus {
            width: 100%;
            height: 100%;
            props: parent.props;
            is_selected: parent.is_selected;
        }


        if (comp.type == "map") : MapComponent {
            width: 100%;
            height: 100%;
            props: parent.props;
            is_selected: parent.is_selected;
            
            // 绑定回调 (示例：打印点击位置)
            // map_clicked(x, y) => {
            //     debug("Map Component Clicked: " + x + ", " + y);
            //     // 这里可以调用 Callback_Factory 的函数将点击事件传回 C++
            //     // Callback_Factory.on_map_click(x, y); 
            // }
        }

    }
}