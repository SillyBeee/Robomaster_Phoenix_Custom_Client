import { ComponentProps } from "../base_component.slint";
import { Callback_Factory } from "../../callback_factory.slint";

// ==========================================
// 1. 通用矩形血条 (用于前哨站、哨兵)
// ==========================================
component UnitBar inherits Rectangle {
    in property <string> label;
    in property <float> hp;
    in property <float> max_hp;
    in property <bool> is_blue;
    in property <length> font_size;

    background: transparent;

    property <float> hp_percent: Math.max(0, Math.min(1, max_hp > 0 ? hp / max_hp : 0));
    property <color> bar_color: is_blue ? #2f8cff : #ff4a4a;

    // 外框
    Rectangle {
        width: 100%;
        height: 100%;
        background: #00000055;
        border-width: 1px;
        border-color: #ffffff22;
        border-radius: 8px;

        // 填充区域（clip 防溢出）
        Rectangle {
            x: 2px; y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            background: transparent;
            border-radius: 6px;
            clip: true;

            Rectangle {
                x: 0; y: 0;
                width: Math.max(0px, parent.width * root.hp_percent);
                height: 100%;
                background: root.bar_color;
                opacity: 0.55;
            }
        }
    }

    // 标题居中
    Text {
        text: root.label;
        color: #ffffff;
        font-size: root.font_size;
        x: parent.width / 2 - self.width / 2;
        y: parent.height / 2 - self.height / 2;
    }

    // 血量数值（靠边）
    Text {
        text: Math.round(root.hp);
        color: #ffffffcc;
        font-size: root.font_size * 0.85;
        y: parent.height - self.height - 2px;
        x: is_blue ? 10px : parent.width - self.width - 10px;
    }
}

// ==========================================
// 2. 基地长矩形血条 (带Logo圈)
// ==========================================
component BaseBar inherits Rectangle {
    in property <float> hp;
    in property <float> max_hp;
    in property <bool> is_blue;
    in property <length> font_size;

    background: transparent;

    property <float> hp_percent: Math.max(0, Math.min(1, max_hp > 0 ? hp / max_hp : 0));
    property <color> theme_color: is_blue ? #2f8cff : #ff4a4a;

    // 长条主体（背景+填充）
    Rectangle {
        width: 100%;
        height: 100%;
        background: #00000055;
        border-width: 1px;
        border-color: root.theme_color ; // 保持类型一致（颜色）
        // Slint 不支持颜色拼接的话就用固定值：
        // border-color: #ffffff22;
        border-radius: 12px;

        // 内部填充 clip（避开圆形 logo 的宽度）
        Rectangle {
            x: is_blue ? parent.height * 0.55 : 2px;
            y: parent.height * 0.28;
            width: (parent.width - (is_blue ? parent.height * 0.55 : 2px) - 2px);
            height: parent.height * 0.48;
            background: transparent;
            border-radius: self.height / 2;
            clip: true;

            Rectangle {
                width: Math.max(0px, parent.width * root.hp_percent);
                height: 100%;
                background: root.theme_color;
                opacity: 0.6;
                border-radius: self.height / 2;
            }
        }
    }

    // 队伍 Logo 圈（覆盖在条上）
    Rectangle {
        z: 10;
        width: parent.height; height: parent.height;
        border-radius: self.width / 2;
        background: root.theme_color;
        x: is_blue ? 0 : parent.width - self.width;
        y: 0;

        Text {
            text: is_blue ? "B" : "R";
            font-size: root.font_size * 1.2;
            font-weight: 900;
            color: white;
            x: parent.width / 2 - self.width / 2;
            y: parent.height / 2 - self.height / 2;
        }
    }

    // 数值居中
    Text {
        text: Math.round(root.hp);
        font-size: root.font_size;
        font-weight: 700;
        color: white;
        x: parent.width / 2 - self.width / 2;
        y: parent.height * 0.3;
    }
}

// ==========================================
// 3. 机器人卡片（矩形）
// ==========================================
component RobotCard inherits Rectangle {
    in property <int> id;
    in property <float> hp;
    in property <float> max_hp;
    in property <bool> is_blue;
    in property <image> avatar;
    in property <length> font_size;

    property <float> hp_percent: Math.max(0, Math.min(1, max_hp > 0 ? hp / max_hp : 0));
    property <color> theme_color: is_blue ? #2f8cff : #ff4a4a;

    background: #00000055;
    border-width: 1px;
    border-color: #ffffff22;
    border-radius: 10px;

    // 编号
    Text {
        text: root.id;
        color: #ffffff;
        font-weight: 800;
        font-size: root.font_size;
        x: parent.width / 2 - self.width / 2;
        y: parent.height * 0.22;
    }

    // 底部血条（矩形圆角，clip 防溢出）
    Rectangle {
        y: parent.height * 0.78;
        x: 6px;
        width: parent.width - 12px;
        height: Math.max(4px, parent.height * 0.12);
        background: #ffffff18;
        border-radius: self.height / 2;
        clip: true;

        Rectangle {
            x: 0; y: 0;
            width: parent.width * root.hp_percent;
            height: 100%;
            background: root.theme_color;
            border-radius: self.height / 2;
        }
    }
}

// ==========================================
// 4. 顶部比分板（保持原 Path，不影响血条问题）
// ==========================================
component ScoreBoard inherits Rectangle {
    in property <length> font_size;

    Path {
        width: 100%; height: 100%;
        fill: #00000080;
        stroke: #444; stroke-width: 1px;
        viewbox-x: 0; viewbox-y: 0; viewbox-width: 200; viewbox-height: 50;
        MoveTo { x: 0; y: 0; }
        LineTo { x: 200; y: 0; }
        LineTo { x: 180; y: 50; }
        LineTo { x: 20; y: 50; }
        Close {}
    }

    HorizontalLayout {
        alignment: center;
        spacing: 10px;

        Text { text: Callback_Factory.game_status.red-score; color: #ff3333; font-size: root.font_size * 1.5; font-weight: 700; }

        VerticalLayout {
            alignment: center;
            Text { text: "Round " + Callback_Factory.game_status.current-round; color: #aaa; font-size: root.font_size * 0.6; horizontal-alignment: center; }
            Text {
                property <int> min: Math.floor(Callback_Factory.game_status.stage-countdown-sec / 60);
                property <int> sec: Callback_Factory.game_status.stage-countdown-sec - (min * 60);
                text: (min < 10 ? "0"+min : min) + ":" + (sec < 10 ? "0"+sec : sec);
                color: white; font-size: root.font_size * 1.2; font-weight: 700; horizontal-alignment: center;
            }
        }

        Text { text: Callback_Factory.game_status.blue-score; color: #0088ff; font-size: root.font_size * 1.5; font-weight: 700; }
    }
}

// ==========================================
// 主组件: GameStatus
// ==========================================
export component GameStatus inherits Rectangle {
    in property <ComponentProps> props;
    in property <bool> is_selected;

    property <length> dynamic_font_size: Callback_Factory.font_size * 0.8px;
    background: transparent;

    VerticalLayout {
        spacing: parent.height * 0.05;

        HorizontalLayout {
            height: 60%;
            alignment: center;
            spacing: -10px;

            // 修：max-hp -> max_hp
            UnitBar { width: parent.width * 0.12; label: "前哨站"; hp: Callback_Factory.global_unit_status.outpost-hp; max_hp: 1500; is_blue: false; font_size: root.dynamic_font_size; }
            UnitBar { width: parent.width * 0.12; label: "哨兵"; hp: 600; max_hp: 600; is_blue: false; font_size: root.dynamic_font_size; }
            BaseBar { width: parent.width * 0.20; hp: Callback_Factory.global_unit_status.base-hp; max_hp: 5000; is_blue: false; font_size: root.dynamic_font_size; }

            ScoreBoard { width: parent.width * 0.12; font_size: root.dynamic_font_size; }

            BaseBar { width: parent.width * 0.20; hp: Callback_Factory.global_unit_status.base-hp; max_hp: 5000; is_blue: true; font_size: root.dynamic_font_size; }
            UnitBar { width: parent.width * 0.12; label: "哨兵"; hp: 600; max_hp: 600; is_blue: true; font_size: root.dynamic_font_size; }
            UnitBar { width: parent.width * 0.12; label: "前哨站"; hp: Callback_Factory.global_unit_status.outpost-hp; max_hp: 1500; is_blue: true; font_size: root.dynamic_font_size; }
        }

        HorizontalLayout {
            height: 40%;
            alignment: center;
            spacing: 20px;

            HorizontalLayout {
                spacing: 2px;
                for i in 6 : RobotCard {
                    width: root.width * 0.05;
                    id: i + 1;
                    is_blue: false;
                    hp: i < Callback_Factory.global_unit_status.robot-hp.length ? Callback_Factory.global_unit_status.robot-hp[i] : 0;
                    max_hp: 100;
                    font_size: root.dynamic_font_size;
                }
            }

            Rectangle {
                width: root.width * 0.1;
                background: #00000080;
                border-radius: self.height / 2;

                HorizontalLayout {
                    alignment: center; spacing: 5px;
                    Text { text: Callback_Factory.global_logistics_status.total-economy-obtained; color: #ff3333; font-weight: 700; font-size: root.dynamic_font_size; }
                    Rectangle { width: 10px; height: 10px; background: #ffd700; border-radius: 5px; y: (parent.height - self.height)/2; }
                    Text { text: Callback_Factory.global_logistics_status.total-economy-obtained; color: #0088ff; font-weight: 700; font-size: root.dynamic_font_size; }
                }
            }

            HorizontalLayout {
                spacing: 2px;
                for i in 6 : RobotCard {
                    width: root.width * 0.05;
                    id: i + 1;
                    is_blue: true;
                    hp: i < Callback_Factory.global_unit_status.robot-hp.length ? Callback_Factory.global_unit_status.robot-hp[i] : 0;
                    max_hp: 100;
                    font_size: root.dynamic_font_size;
                }
            }
        }
    }
}