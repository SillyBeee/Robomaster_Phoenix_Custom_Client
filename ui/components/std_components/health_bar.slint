import { ComponentProps } from "../base_component.slint";

// 注意：不再包含 Base_Component，它只是一个纯粹的内容组件
export component Health_Bar_Content inherits Rectangle {
    in property <ComponentProps> props;
    in property <bool> is_selected;
    
    // 特有属性
    in property <float> current_hp: 60.0;
    in property <float> max_hp: 100.0;
    in property <brush> bar_color: #ff4444;

    // 填满父容器 (即 Base_Component 的内容区域)
    width: 100%;
    height: 100%;
    background: #333333;
    border-radius: 4px;
    clip: true;

    // 动态血条
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.current_hp / root.max_hp);
        height: 100%;
        background: root.bar_color;
    }

    // 文字
    Text {
        text: Math.round(root.current_hp) + " / " + Math.round(root.max_hp);
        color: white;
        font-size: root.height * 0.6; // 使用 root.height 而不是 props
        x: parent.width / 2 - self.width / 2;
        y: parent.height / 2 - self.height / 2;
    }
    
    // 选中高亮
    if (root.is_selected) : Rectangle {
        border-width: 1px;
        border-color: white;
        opacity: 0.3;
    }
}