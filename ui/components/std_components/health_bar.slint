import { ComponentProps } from "../base_component.slint";
import { Callback-Factory, Callback-Factory } from "../../callback_factory.slint";

export component HealthBar inherits Rectangle {
    in property <ComponentProps> props;
    in property <bool> is_selected;

    // --- 数据接口 ---
    in property <image> avatar_image; // 头像图片
    in property <float> max_hp: Callback-Factory.robot_static_status.max-health;
    in property <float> current_hp: Callback-Factory.robot_dynamic_status.current-health;
    in property <float> current_power: Callback-Factory.robot_dynamic_status.current-chassis-energy; // 剩余底盘能量

    // --- 尺寸配置 ---
    in property <length> bar_height: 30px;
    in property <length> bar_width: 200px;
    in property <length> avatar_size: 50px;

    width: root.bar_width + root.avatar_size; 
    height: root.avatar_size + 10px;
    background: transparent;

    // 计算血量百分比 (0.0 - 1.0)
    property <float> hp_percent: Math.max(0, Math.min(1, root.current_hp / root.max_hp));

    // ============================================
    // 1. 红色血条 (背景 + 前景)
    // ============================================
    // 血条容器 (平行四边形)
    Rectangle {
        x: root.avatar_size * 0.8; // 稍微插入头像后面
        y: (root.avatar_size - root.bar_height) / 2;
        width: root.bar_width;
        height: root.bar_height;
        clip: true; // 裁剪超出部分

        // 红色背景 (底色)
        Path {
            width: 100%; height: 100%;
            fill: #4a000080; // 深红半透明背景
            stroke: #ff0000;
            stroke-width: 1px;
            
            // 绘制平行四边形
            MoveTo { x: 0; y: 0; }
            LineTo { x: parent.width/1px - 20; y: 0; } // 上边
            LineTo { x: parent.width/1px; y: parent.height/1px; } // 右斜边
            LineTo { x: 20; y: parent.height/1px; } // 下边
            LineTo { x: 0; y: 0; } // 左斜边 (被头像挡住，无所谓)
            Close {}
        }

        // 红色前景 (实际血量)
        Path {
            width: parent.width * root.hp_percent; // 宽度随血量变化
            height: 100%;
            fill: #ff3333; // 亮红色
            
            // 同样的平行四边形逻辑，但宽度动态变化
            MoveTo { x: 0; y: 0; }
            LineTo { x: parent.width/1px - 20; y: 0; }
            LineTo { x: parent.width/1px; y: parent.height/1px; }
            LineTo { x: 20; y: parent.height/1px; }
            LineTo { x: 0; y: 0; }
            Close {}
            
            // 动画过渡
            animate width { duration: 200ms; easing: ease-out; }
        }

        // 血量文字
        Text {
            text: Math.round(root.current_hp) + " / " + Math.round(root.max_hp);
            color: white;
            font-size: 14px;
            font-weight: 700;
            x: parent.width / 2 - self.width / 2;
            y: parent.height / 2 - self.height / 2;
        }
    }

    // ============================================
    // 2. 蓝色功率条 (底部)
    // ============================================
    Rectangle {
        x: root.avatar_size * 0.9;
        y: root.avatar_size * 0.85; // 位于血条下方
        width: root.bar_width * 0.9;
        height: 6px;

        // 功率条背景
        Rectangle {
            width: 100%; height: 100%;
            background: #001a3380; // 深蓝背景
            
            // 简单的斜切效果可以用 Path，这里简化用 Rectangle
        }

        // 功率条前景 (假设最大功率 200，这里做个简单的进度演示)
        Rectangle {
            width: Math.min(parent.width, parent.width * (root.current_power / 200.0)); 
            height: 100%;
            background: #0088ff;
        }
        
        // 功率文字 (在右侧)
        Text {
            x: parent.width + 10px;
            y: -4px;
            text: Math.round(root.current_power) + " kW";
            color: white;
            font-size: 12px;
            font-weight: 700;
        }
    }

    // ============================================
    // 3. 头像框 (最上层)
    // ============================================
    Rectangle {
        x: 0;
        y: 0;
        width: root.avatar_size;
        height: root.avatar_size;
        border-radius: root.avatar_size / 2;
        background: black; // 默认黑色底
        border-width: 2px;
        border-color: #333;
        clip: true; // 裁剪图片为圆形

        // 头像图片
        Image {
            width: 100%;
            height: 100%;
            source: root.avatar_image;
            image-fit: cover;
        }
        
        // 左侧红色光晕装饰 (模仿图片左边的红边)
        Rectangle {
            x: -2px;
            y: 0;
            width: parent.width;
            height: parent.height;
            border-radius: parent.width / 2;
            border-width: 2px;
            border-color: transparent;
            // 这里很难做复杂的渐变边框，简单模拟左侧红边
        }
    }
    
    // 选中状态指示
    if (root.is_selected) : Rectangle {
        width: 100%; height: 100%;
        border-width: 1px;
        border-color: white;
        opacity: 0.3;
        background: transparent;
    }
}