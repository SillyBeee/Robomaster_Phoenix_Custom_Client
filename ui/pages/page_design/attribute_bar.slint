import { Callback_Factory, Callback-Factory } from "../../callback_factory.slint";
import { Slider, SpinBox, Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

// 属性栏
export component Attribute_Bar inherits Rectangle {
    width: 260px; 
    height: 100%; // 确保占满父容器高度
    background: #1d1f2a;

    // --- 属性定义 ---
    out property <bool> has_selection: 
        Callback_Factory.current_component_index >= 0 && Callback_Factory.current_component_index < Callback_Factory.components.length;
    
    property <[brush]> palette_colors: [#44ffaa, #ff8844, #4488ff, #ffffff, #aa88ff ,#00000000];
    
    property <string> current_type: has_selection ? Callback_Factory.components[Callback_Factory.current_component_index].type : "";
    property <int> current_idx: Callback_Factory.current_component_index;

    // --- 逻辑函数 (保持不变) ---
    public function is_valid_index(index: int) -> bool {
        return index >= 0 && index < Callback_Factory.components.length;
    }

    public function set_component_rel_width(index: int, value: float) {
        if (!is_valid_index(index)) { return; }
        let current = Callback_Factory.components[index];
        Callback_Factory.components[index] = {
            type: current.type, color: current.color, rel_width: value, rel_height: current.rel_height,
            rel_x: current.rel_x, rel_y: current.rel_y, opacity: current.opacity, layer: current.layer,
        };
    }

    public function set_component_rel_height(index: int, value: float) {
        if (!is_valid_index(index)) { return; }
        let current = Callback_Factory.components[index];
        Callback_Factory.components[index] = {
            type: current.type, color: current.color, rel_width: current.rel_width, rel_height: value,
            rel_x: current.rel_x, rel_y: current.rel_y, opacity: current.opacity, layer: current.layer,
        };
    }

    public function set_component_opacity(index: int, value: float) {
        if (!is_valid_index(index)) { return; }
        let current = Callback_Factory.components[index];
        Callback_Factory.components[index] = {
            type: current.type, color: current.color, rel_width: current.rel_width, rel_height: current.rel_height,
            rel_x: current.rel_x, rel_y: current.rel_y, opacity: value, layer: current.layer,
        };
    }
    
    public function set_component_layer(index: int, value: int) {
        if (!is_valid_index(index)) { return; }
        let current = Callback_Factory.components[index];
        Callback_Factory.components[index] = {
            type: current.type, color: current.color, rel_width: current.rel_width, rel_height: current.rel_height,
            rel_x: current.rel_x, rel_y: current.rel_y, opacity: current.opacity, layer: value,
        };
    }

    public function set_component_color(index: int, color_value: brush) {
        if (!is_valid_index(index)) { return; }
        let current = Callback_Factory.components[index];
        Callback_Factory.components[index] = {
            type: current.type, color: color_value, rel_width: current.rel_width, rel_height: current.rel_height,
            rel_x: current.rel_x, rel_y: current.rel_y, opacity: current.opacity, layer: current.layer,
        };
    }

    // --- 界面布局 ---
    VerticalLayout {
        padding: 15px; 
        spacing: 15px; 
        alignment: start;

        // 1. 标题区 (固定高度)
        VerticalLayout {
            spacing: 5px;
            Text {
                text: "属性面板";
                color: white;
                font-size: Callback-Factory.font_size * 1.5px;
                font-weight: 700;
            }
            Rectangle { height: 2px; background: #3a3f55; width: 100%; }
        }

        // 2. 当前选中状态卡片 (固定高度)
        Rectangle {
            height: 40px;
            background: #2a2d3d;
            border-radius: 4px;
            
            HorizontalLayout {
                padding-left: 10px; padding-right: 10px;
                alignment: center;
                Text {
                    text: root.has_selection ? "选中: #" + root.current_idx + " " + root.current_type : "未选择组件"; 
                    color: root.has_selection ? #44ffaa : #888;
                    font-size:  Callback-Factory.font_size * 1.4px;
                    vertical-alignment: center;
                }
            }
        }

        // 3. 保存按钮 (固定高度)
        Button {
            text: "保存布局 (Save)";
            enabled: root.has_selection;
            height:  Callback-Factory.font_size * 3.2px;
            primary: true; 
            clicked => { Callback_Factory.save_to_json(); }
        }

        Rectangle { height: 1px; background: #3a3f55; width: 100%; }

        // 4. 属性控制区 (占据剩余空间，可滚动)
        // 使用 Flickable 包裹内容，确保小屏幕也能显示完整
        Flickable {
            viewport-height: controls_layout.preferred-height;
            
            controls_layout := VerticalLayout {
                spacing: 12px;
                alignment: start; // 内容靠上对齐

                if (root.has_selection) : VerticalLayout {
                    spacing: 15px; // 增加内部间距

                    // --- 宽度 ---
                    VerticalLayout {
                        spacing: 4px;
                        HorizontalLayout {
                            alignment: space-between;
                            Text { text: "宽度 (Width)"; color: #8aa0ff; font-size:  Callback-Factory.font_size * 1.2px; }
                            Text { 
                                text: Math.round(Callback_Factory.components[root.current_idx].rel_width * 100) + "%"; 
                                color: white; font-size:  Callback-Factory.font_size * 1.2px;
                            }
                        }
                        Slider {
                            minimum: 1; maximum: 100; step: 1;
                            value: Callback_Factory.components[root.current_idx].rel_width * 100;
                            changed(v) => { root.set_component_rel_width(root.current_idx, v / 100); }
                        }
                    }

                    // --- 高度 ---
                    VerticalLayout {
                        spacing: 4px;
                        HorizontalLayout {
                            alignment: space-between;
                            Text { text: "高度 (Height)"; color: #8aa0ff; font-size:  Callback-Factory.font_size * 1.2px; }
                            Text { 
                                text: Math.round(Callback_Factory.components[root.current_idx].rel_height * 100) + "%"; 
                                color: white; font-size:  Callback-Factory.font_size * 1.2px; 
                            }
                        }
                        Slider {
                            minimum: 1; maximum: 100; step: 1;
                            value: Callback_Factory.components[root.current_idx].rel_height * 100;
                            changed(v) => { root.set_component_rel_height(root.current_idx, v / 100); }
                        }
                    }

                    // --- 透明度 ---
                    VerticalLayout {
                        spacing: 4px;
                        HorizontalLayout {
                            alignment: space-between;
                            Text { text: "透明度 (Opacity)"; color: #8aa0ff; font-size:  Callback-Factory.font_size * 1.2px; }
                            Text { 
                                text: Math.round(Callback_Factory.components[root.current_idx].opacity * 100) + "%"; 
                                color: white; font-size:  Callback-Factory.font_size * 1.2px; 
                            }
                        }
                        Slider {
                            minimum: 0.0; maximum: 1.0; step: 0.05;
                            value: Callback_Factory.components[root.current_idx].opacity;
                            changed(v) => { root.set_component_opacity(root.current_idx, v); }
                        }
                    }

                    // --- 层级 ---
                    HorizontalLayout {
                        alignment: space-between;
                        Text { text: "层级 (Layer)"; color: #8aa0ff; font-size:  Callback-Factory.font_size * 1.2px; vertical-alignment: center; }
                        SpinBox {
                            width: 100px;
                            minimum: -10; maximum: 10;
                            value: Callback_Factory.components[root.current_idx].layer;
                            edited(v) => { root.set_component_layer(root.current_idx, v); }
                        }
                    }

                    // --- 颜色 ---
                    VerticalLayout {
                        spacing: 8px;
                        Text { text: "主题色 (Color)"; color: #8aa0ff; font-size:  Callback-Factory.font_size * 1.2px; }
                        
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center; 
                            for col[i] in root.palette_colors: Rectangle {
                                width: 28px; height: 28px; border-radius: 14px; 
                                background: col;
                                border-width: (Callback_Factory.components[root.current_idx].color == col) ? 2px : 0px;
                                border-color: white;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: #00000080;

                                TouchArea {
                                    clicked => { root.set_component_color(root.current_idx, col); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
