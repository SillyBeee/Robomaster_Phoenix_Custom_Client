import { Base_Component } from "../components/base_component.slint";
import { Slider,  SpinBox } from "std-widgets.slint";

export component Page_Design inherits Rectangle {
    width: 100%;
    height: 100%;
    background: @linear-gradient(180deg, #5c6175 0%, #080114 100%);
    in-out property<int> selected_index: 0;

    in-out property<[{
        color: brush,
        width: length,
        height: length,
        x: length,
        y: length,
        opacity: float,
        layer: int,
    }]> components: [
        { color: #44ffaa, width: 140px, height: 90px, x: 120px, y: 150px, opacity: 0.9, layer: 0 },
        { color: #ff8844, width: 100px, height: 100px, x: 320px, y: 220px, opacity: 1.0, layer: 1 },
    ];

    property<[brush]> palette_colors: [#44ffaa, #ff8844, #4488ff, #ffffff, #aa88ff];
    property<bool> has_selection: selected_index >= 0 && selected_index < components.length;

    public function is_valid_index(index: int) -> bool {
        return index >= 0 && index < components.length;
    }

    public function move_component(index: int, dx: length, dy: length) {
        if (!is_valid_index(index)) {
            return;
        }
        let current = components[index];
        components[index] = {
            color: current.color,
            width: current.width,
            height: current.height,
            x: current.x + dx,
            y: current.y + dy,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    public function set_component_x(index: int, px_value: float) {
        if (!is_valid_index(index)){
            return;
        } 
        let current = components[index];
        components[index] = {
            color: current.color,
            width: current.width,
            height: current.height,
            x: px_value * 1px,
            y: current.y,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    public function set_component_y(index: int, px_value: float) {
        if (!is_valid_index(index)){
            return;
        } 
        let current = components[index];
        components[index] = {
            color: current.color,
            width: current.width,
            height: current.height,
            x: current.x,
            y: px_value * 1px,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    public function set_component_width(index: int, px_value: float) {
        if (!is_valid_index(index)) {
            return;
        }
        let current = components[index];
        components[index] = {
            color: current.color,
            width: px_value * 1px,
            height: current.height,
            x: current.x,
            y: current.y,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    public function set_component_height(index: int, px_value: float) {
        if (!is_valid_index(index)) {
            return;
        }
        let current = components[index];
        components[index] = {
            color: current.color,
            width: current.width,
            height: px_value * 1px,
            x: current.x,
            y: current.y,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    public function set_component_opacity(index: int, value: float) {
        if (!is_valid_index(index)) {
            return;
        }
        let current = components[index];
        components[index] = {
            color: current.color,
            width: current.width,
            height: current.height,
            x: current.x,
            y: current.y,
            opacity: value,
            layer: current.layer,
        };
    }

    public function set_component_layer(index: int, value: int) {
        if (!is_valid_index(index)) {
            return;
        }
        let current = components[index];
        components[index] = {
            color: current.color,
            width: current.width,
            height: current.height,
            x: current.x,
            y: current.y,
            opacity: current.opacity,
            layer: value,
        };
    }

    public function set_component_color(index: int, color_value: brush) {
        if (!is_valid_index(index)){
            return;
        }
        let current = components[index];
        components[index] = {
            color: color_value,
            width: current.width,
            height: current.height,
            x: current.x,
            y: current.y,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    GridLayout {
        spacing: 12px;
        padding: 16px;

        Rectangle {
            width: 160px;
            height: 100%;
            background: #1d1f2a;
            Text { text: "组件库\n(占位示例)"; color: white; x: 16px; y: 16px; }
        }

        Rectangle {
            background: #0d0f1a;
            border-width: 1px;
            border-color: #303344;

            for comp[i] in components: Base_Component {
                comp_x: comp.x;
                comp_y: comp.y;
                comp_width: comp.width;
                comp_height: comp.height;
                comp_color: comp.color;
                opacity_value: comp.opacity;
                layer: comp.layer;
                is_selected: i == selected_index;

                request_focus => {
                    selected_index = i;
                    self.focus();
                }
                request_drag(dx, dy) => {
                    root.move_component(i, dx, dy);
                }
            }
        }

        // Rectangle {
        //     width: 240px;
        //     height: 100%;
        //     background: #1d1f2a;
        //     padding: 14px;

        //     VerticalLayout {
        //         spacing: 10px;
        //         Text { text: "属性面板"; color: white; font-size: 20px; }
        //         Text { text: has_selection ? "当前组件 #" + selected_index : "请选择组件"; color: #cfd8ff; }

        //         Text { text: "X (px)"; color: #8aa0ff; }
        //         Slider {
        //             enabled: has_selection;
        //             from: 0; to: 800; step: 1;
        //             value: has_selection ? components[selected_index].x / 1px : 0;
        //             value-changed => set_component_x(selected_index, self.value);
        //         }

        //         Text { text: "Y (px)"; color: #8aa0ff; }
        //         Slider {
        //             enabled: has_selection;
        //             from: 0; to: 500; step: 1;
        //             value: has_selection ? components[selected_index].y / 1px : 0;
        //             value-changed => set_component_y(selected_index, self.value);
        //         }

        //         Text { text: "宽度 (px)"; color: #8aa0ff; }
        //         Slider {
        //             enabled: has_selection;
        //             from: 40; to: 400; step: 1;
        //             value: has_selection ? components[selected_index].width / 1px : 0;
        //             value-changed => set_component_width(selected_index, self.value);
        //         }

        //         Text { text: "高度 (px)"; color: #8aa0ff; }
        //         Slider {
        //             enabled: has_selection;
        //             from: 40; to: 300; step: 1;
        //             value: has_selection ? components[selected_index].height / 1px : 0;
        //             value-changed => set_component_height(selected_index, self.value);
        //         }

        //         Text { text: "透明度"; color: #8aa0ff; }
        //         Slider {
        //             enabled: has_selection;
        //             from: 0.2; to: 1.0; step: 0.01;
        //             value: has_selection ? components[selected_index].opacity : 1.0;
        //             value-changed => set_component_opacity(selected_index, self.value);
        //         }

        //         Text { text: "层级"; color: #8aa0ff; }
        //         SpinBox {
        //             enabled: has_selection;
        //             from: -10; to: 10;
        //             value: has_selection ? components[selected_index].layer : 0;
        //             value-changed => set_component_layer(selected_index, self.value);
        //         }

        //         Text { text: "颜色"; color: #8aa0ff; }
        //         HorizontalLayout {
        //             spacing: 6px;
        //             for palette_color[i] in palette_colors: Rectangle {
        //                 width: 26px; height: 26px; radius: 6px;
        //                 background: palette_color;
        //                 border-width: 2px;
        //                 border-color: has_selection && components[selected_index].color == palette_color ? #ffd54f : #444a63;

        //                 TouchArea {
        //                     enabled: has_selection;
        //                     clicked => set_component_color(selected_index, palette_color);
        //                 }
        //             }
        //         }
        //     }
        // }
    }
}