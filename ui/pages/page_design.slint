import { Base_Component } from "../components/base_component.slint";
import { Slider, SpinBox } from "std-widgets.slint";
import { Callback_Factory as callback_factory, Callback-Factory } from "../callback_factory.slint";

export component Page_Design inherits Rectangle {
    width: 100%;
    height: 100%;
    background: @linear-gradient(180deg, #5c6175 0%, #080114 100%);
    
    // 当前选中的组件索引
    in-out property<int> selected_index: Callback-Factory.current_component_index;

    // 组件数据模型 (全部使用相对百分比)
    in-out property<[{
        color: brush,
        rel_width: float,
        rel_height: float,
        rel_x: float,
        rel_y: float,
        opacity: float,
        layer: int,
    }]> components: [
        { color: #44ffaa, rel_width: 0.2, rel_height: 0.1, rel_x: 0.1, rel_y: 0.1, opacity: 0.9, layer: 0 },
        { color: #ff8844, rel_width: 0.2, rel_height: 0.2, rel_x: 0.4, rel_y: 0.3, opacity: 1.0, layer: 1 },
    ];

    property<[brush]> palette_colors: [#44ffaa, #ff8844, #4488ff, #ffffff, #aa88ff];
    property<bool> has_selection: selected_index >= 0 && selected_index < components.length;

    public function is_valid_index(index: int) -> bool {
        return index >= 0 && index < components.length;
    }

    // 更新 X (百分比)
    public function set_component_rel_x(index: int, value: float) {
        if (!is_valid_index(index)) { return; } 
        let current = components[index];
        components[index] = {
            color: current.color,
            rel_width: current.rel_width,
            rel_height: current.rel_height,
            rel_x: value,
            rel_y: current.rel_y,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    // 更新 Y (百分比)
    public function set_component_rel_y(index: int, value: float) {
        if (!is_valid_index(index)) { return; } 
        let current = components[index];
        components[index] = {
            color: current.color,
            rel_width: current.rel_width,
            rel_height: current.rel_height,
            rel_x: current.rel_x,
            rel_y: value,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    // 更新 Width (百分比)
    public function set_component_rel_width(index: int, value: float) {
        if (!is_valid_index(index)) { return; }
        let current = components[index];
        components[index] = {
            color: current.color,
            rel_width: value,
            rel_height: current.rel_height,
            rel_x: current.rel_x,
            rel_y: current.rel_y,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    // 更新 Height (百分比)
    public function set_component_rel_height(index: int, value: float) {
        if (!is_valid_index(index)) { return; }
        let current = components[index];
        components[index] = {
            color: current.color,
            rel_width: current.rel_width,
            rel_height: value,
            rel_x: current.rel_x,
            rel_y: current.rel_y,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    public function set_component_opacity(index: int, value: float) {
        if (!is_valid_index(index)) { return; }
        let current = components[index];
        components[index] = {
            color: current.color,
            rel_width: current.rel_width,
            rel_height: current.rel_height,
            rel_x: current.rel_x,
            rel_y: current.rel_y,
            opacity: value,
            layer: current.layer,
        };
    }

    public function set_component_layer(index: int, value: int) {
        if (!is_valid_index(index)) { return; }
        let current = components[index];
        components[index] = {
            color: current.color,
            rel_width: current.rel_width,
            rel_height: current.rel_height,
            rel_x: current.rel_x,
            rel_y: current.rel_y,
            opacity: current.opacity,
            layer: value,
        };
    }

    public function set_component_color(index: int, color_value: brush) {
        if (!is_valid_index(index)) { return; }
        let current = components[index];
        components[index] = {
            color: color_value,
            rel_width: current.rel_width,
            rel_height: current.rel_height,
            rel_x: current.rel_x,
            rel_y: current.rel_y,
            opacity: current.opacity,
            layer: current.layer,
        };
    }

    GridLayout {
        spacing: 12px;
        padding: 16px;

        // 画布区域
        Rectangle {
            background: #0d0f1a;
            border-width: 1px;
            border-color: #303344;
            clip: true; // 防止组件拖出边界显示

            for comp[i] in components: Base_Component {
                // 传入上下文
                container_width: parent.width;
                container_height: parent.height;
                container_index: i;

                // 传入核心百分比属性
                rel_x: comp.rel_x;
                rel_y: comp.rel_y;
                rel_width: comp.rel_width;
                rel_height: comp.rel_height;

                // 传入外观属性
                comp_color: comp.color;
                opacity_value: comp.opacity;
                layer: comp.layer;
                is_selected: i == selected_index;
            }
        }

        // 属性面板
        Rectangle {
            width: 240px;
            height: 100%;
            background: #1d1f2a;
            padding: 14px;

            VerticalLayout {
                spacing: 10px;
                Text { text: "属性面板"; color: white; font-size: 20px; }
                Text { text: has_selection ? "当前组件 #" + selected_index : "请选择组件"; color: #cfd8ff; }

                // X 轴位置 (百分比 0-100)
                Text { text: "X (%)"; color: #8aa0ff; }
                Slider {
                    enabled: has_selection;
                    minimum: 0;
                    maximum: 100;
                    step: 0.1;
                    value: has_selection ? components[selected_index].rel_x * 100 : 0;
                    changed(value) => {
                        set_component_rel_x(selected_index, value / 100);
                    }
                }

                // Y 轴位置 (百分比 0-100)
                Text { text: "Y (%)"; color: #8aa0ff; }
                Slider {
                    enabled: has_selection;
                    minimum: 0;
                    maximum: 100;
                    step: 0.1;
                    value: has_selection ? components[selected_index].rel_y * 100 : 0;
                    changed(value) => {
                        set_component_rel_y(selected_index, value / 100);
                    }
                }

                // 宽度 (百分比 0-100)
                Text { text: "宽度 (%)"; color: #8aa0ff; }
                Slider {
                    enabled: has_selection;
                    minimum: 1; // 最小宽度 1%
                    maximum: 100;
                    step: 0.1;
                    value: has_selection ? components[selected_index].rel_width * 100 : 0;
                    changed(value) => {
                        set_component_rel_width(selected_index, value / 100);
                    }
                }

                // 高度 (百分比 0-100)
                Text { text: "高度 (%)"; color: #8aa0ff; }
                Slider {
                    enabled: has_selection;
                    minimum: 1; // 最小高度 1%
                    maximum: 100;
                    step: 0.1;
                    value: has_selection ? components[selected_index].rel_height * 100 : 0;
                    changed(value) => {
                        set_component_rel_height(selected_index, value / 100);
                    }
                }

                Text { text: "透明度"; color: #8aa0ff; }
                Slider {
                    enabled: has_selection;
                    minimum: 0.1;
                    maximum: 1.0;
                    step: 0.01;
                    value: has_selection ? components[selected_index].opacity : 1.0;
                    changed(value) => {
                        set_component_opacity(selected_index, value);
                    }
                }

                Text { text: "层级"; color: #8aa0ff; }
                SpinBox {
                    enabled: has_selection;
                    minimum: -10;
                    maximum: 10;
                    value: has_selection ? components[selected_index].layer : 0;
                    edited(value) => {
                        set_component_layer(selected_index, value);
                    }
                }

                Text { text: "颜色"; color: #8aa0ff; }
                HorizontalLayout {
                    spacing: 6px;
                    for palette_color[i] in palette_colors: Rectangle {
                        width: 26px; height: 26px; 
                        // radius: 6px;
                        background: palette_color;
                        border-width: 2px;
                        border-color: has_selection && components[selected_index].color == palette_color ? #ffd54f : #444a63;

                        TouchArea {
                            enabled: has_selection;
                            clicked => {
                                set_component_color(selected_index, palette_color);
                            }
                        }
                    }
                }
            }
        }
    }
}